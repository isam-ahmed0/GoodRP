<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GoodRP.Avalonia.Views.SettingsPage">

    <Border Background="#1A1A2E" Padding="30,40,30,30">
        <ScrollViewer>
            <StackPanel Spacing="14">

                <!-- GUI Switcher -->
                <TextBlock Text="GUI version:" FontSize="11" Foreground="#B9BBBE"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <RadioButton Content="Classic" GroupName="Gui" x:Name="RbClassic" MinWidth="100"/>
                    <RadioButton Content="9XT (Modern)" GroupName="Gui" x:Name="Rb9xt" MinWidth="100"/>
                    <RadioButton Content="Avalonia" GroupName="Gui" x:Name="RbAvalonia" MinWidth="100" IsChecked="True"/>
                </StackPanel>

                <!-- Activity Type -->
                <TextBlock Text="Activity Type Override" FontSize="11" Foreground="#B9BBBE" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <RadioButton Content="Auto" GroupName="Activity" x:Name="RbAuto" IsChecked="True" MinWidth="80"/>
                    <RadioButton Content="Listening" GroupName="Activity" x:Name="RbListening" MinWidth="80"/>
                    <RadioButton Content="Watching" GroupName="Activity" x:Name="RbWatching" MinWidth="80"/>
                </StackPanel>

                <!-- Toggles -->
                <StackPanel Spacing="8" Margin="0,10,0,0">
                    <CheckBox Content="Auto-show on Discord" x:Name="TglAutoShow" MinWidth="200"/>
                    <CheckBox Content="Show album art" x:Name="TglShowArt" IsChecked="True" MinWidth="200"/>
                    <CheckBox Content="Art finder fallback (Deezer/iTunes)" x:Name="TglArtFinder" IsChecked="True" MinWidth="200"/>
                    <CheckBox Content="Enable MCP Server (AI agents)" x:Name="TglMcp" MinWidth="200"/>
                    <CheckBox Content="Show balloon notification" x:Name="TglNotify" IsChecked="True" MinWidth="200"/>
                    <CheckBox Content="Enable global hotkeys" x:Name="TglHotkeys" IsChecked="True" MinWidth="200"/>
                </StackPanel>

                <!-- Hotkey Info -->
                <TextBlock Text="Show / Hide hotkeys (edit in config.json):" FontSize="10" Foreground="#72767D" Margin="0,10,0,0"/>

                <!-- App Filtering -->
                <TextBlock Text="App Filtering" FontSize="11" Foreground="#B9BBBE" Margin="0,10,0,0"/>

                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,4">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Allowed apps:" FontSize="10" Foreground="#72767D"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Ignored apps:" FontSize="10" Foreground="#72767D" Margin="20,0,0,0"/>

                    <ListBox Grid.Row="1" Grid.Column="0" Background="#28283C" Foreground="White" Height="80"
                             ItemsSource="{Binding AllowedApps}" x:Name="AllowedList"/>
                    <ListBox Grid.Row="1" Grid.Column="2" Background="#28283C" Foreground="White" Height="80"
                             ItemsSource="{Binding IgnoredApps}" x:Name="IgnoredList"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBox Width="200" Height="26" Watermark="App name" x:Name="TxtAllowed"
                             Background="#28283C" Foreground="White"/>
                    <Button Content="+" Width="30" Height="26" Background="#5865F2" Foreground="White" CornerRadius="4"
                            Click="AddAllowed_Click"/>
                    <Button Content="-" Width="30" Height="26" Background="#50505F" Foreground="White" CornerRadius="4"
                            Click="RemoveAllowed_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
