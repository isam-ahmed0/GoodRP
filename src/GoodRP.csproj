<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>..\app.manifest</ApplicationManifest>
    <ApplicationIcon>..\GoodRP.ico</ApplicationIcon>
    <AssemblyName>GoodRP</AssemblyName>
    <RootNamespace>GoodRP</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>GoodRP</Authors>
    <Description>Lightweight Discord Rich Presence client for media playback</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="ModelContextProtocol" Version="1.4.0" />
    <Reference Include="DiscordRPC">
      <HintPath>..\Discord-CustomRP-master\CustomRPC\DiscordRPC.dll</HintPath>
    </Reference>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
